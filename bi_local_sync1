# =============================================================================
# DRIVE CORE & SLOTTED LOCK SYSTEM
# =============================================================================
def get_drive_service():
    creds = None
    if os.path.exists('token.json'):
        creds = Credentials.from_authorized_user_file('token.json', SCOPES)
    if not creds or not creds.valid:
        if creds and creds.expired and creds.refresh_token:
            creds.refresh(Request())
        else:
            flow = InstalledAppFlow.from_client_secrets_file('credentials.json', SCOPES)
            creds = flow.run_local_server(port=0)
        with open('token.json', 'w') as token:
            token.write(creds.to_json())
    return build('drive', 'v3', credentials=creds)


def acquire_global_lock_slotted(service, folder_id, my_id, slot_id, timeout=200, wait_time=6):
    """Checks if global capacity allows for a new task across all devices."""
    start_time = time.time()
    my_lock_name = f"LOCK_D{my_id}_S{slot_id}.lock"

    while time.time() - start_time < timeout:
        try:
            query = f"'{folder_id}' in parents and trashed=false and name contains 'LOCK_'"
            results = service.files().list(q=query, fields="files(id, name, createdTime)").execute()
            locks = results.get('files', [])

            # Check if we already own a lock here
            if any(l['name'] == my_lock_name for l in locks):
                return True

            # Clean stale locks
            active_count = 0
            now = datetime.now(timezone.utc)
            for l in locks:
                created_time = datetime.fromisoformat(l['createdTime'].replace('Z', '+00:00'))
                if (now - created_time).total_seconds() > LOCK_TTL_SECONDS:
                    service.files().delete(fileId=l['id']).execute()
                else:
                    active_count += 1

            if active_count < MAX_INTER_CONCURRENCY:
                file_metadata = {
                    'name': my_lock_name,
                    'parents': [folder_id],
                    'description': f"Device {my_id} Slot {slot_id}"
                }
                service.files().create(body=file_metadata, fields='id').execute()
                return True
        except Exception as e:
            pass  # Suppress spammy network errors

        time.sleep(wait_time)
    return False


def release_global_lock_slotted(service, folder_id, my_id, slot_id):
    try:
        my_lock_name = f"LOCK_D{my_id}_S{slot_id}.lock"
        query = f"name='{my_lock_name}' and '{folder_id}' in parents and trashed=false"
        results = service.files().list(q=query, fields="files(id)").execute()
        for item in results.get('files', []):
            service.files().delete(fileId=item['id']).execute()
    except Exception:
        pass


def purge_all_locks(service, folder_id):
    """Used strictly for initial startup scrubbing."""
    try:
        query = f"'{folder_id}' in parents and trashed=false and name contains 'LOCK_'"
        results = service.files().list(q=query, fields="files(id)").execute()
        for item in results.get('files', []):
            service.files().delete(fileId=item['id']).execute()
    except Exception:
        pass


def _upload_item(service, local_path, g_id, log_q, slot, device_label):
    log_q.put((slot, f"[{device_label}] Starting upload of: {local_path}"))
    file_metadata = {'name': os.path.basename(local_path), 'parents': [g_id]}
    media = MediaFileUpload(local_path, resumable=True)
    request = service.files().create(body=file_metadata, media_body=media, fields='id')
    response = None
    while response is None:
        _, response = request.next_chunk()
    log_q.put((slot, f"Successfully uploaded: {os.path.basename(local_path)} (ID: {response.get('id')})"))


# =============================================================================
# WORKERS & DYNAMIC INVOKE
# =============================================================================
def concurrency_wrapper(start_delay, intra_sem, slot_id, log_queue, api_lock, my_id, choice, lock_wait, **kwargs):
    """The Gatekeeper: Staggers invocation, manages local capacity, then global capacity."""

    # --- INTRA-INSTRUCTION COUNTDOWN/TIMER ---
    if start_delay > 0:
        log_queue.put((slot_id, f"Intra-instruction stagger: Waiting {start_delay}s before starting..."))
        for i in range(start_delay, 0, -1):
            if i <= 3 or i % 5 == 0:
                log_queue.put((slot_id, f"Invoking step in {i}s..."))
            time.sleep(1)

    log_queue.put((slot_id, f"Queued: Waiting for local slot (Max {MAX_INTRA_CONCURRENCY})..."))

    with intra_sem:
        log_queue.put((slot_id, "Local slot acquired. Negotiating Global Inter-device access..."))
        service = get_drive_service()

        if acquire_global_lock_slotted(service, LOCK_FOLDER_ID, my_id, slot_id, wait_time=lock_wait):
            try:
                script_path = kwargs.get('script_path', [None])[0]
                func_name = kwargs.get('run', [None, None])[1]

                if func_name == "trigger_sync":
                    log_queue.put((slot_id, "Executing fallback sync worker logic..."))
                    return

                if not script_path or not os.path.exists(script_path):
                    log_queue.put((slot_id, "Error: Script path invalid."))
                    return

                spec = importlib.util.spec_from_file_location("ext_mod", script_path)
                module = importlib.util.module_from_spec(spec)
                spec.loader.exec_module(module)
                func = getattr(module, func_name)

                # Execute with local API lock to prevent thread collisions on local files
                with api_lock:
                    func(slot_id=slot_id, log_queue=log_queue, api_lock=api_lock, my_id=my_id, **kwargs)

            except Exception as e:
                log_queue.put((slot_id, f"Execution Error: {e}"))
            finally:
                release_global_lock_slotted(service, LOCK_FOLDER_ID, my_id, slot_id)
                log_queue.put((slot_id, "Task complete. Released Global slot."))
        else:
            log_queue.put((slot_id, "Global Timeout: Inter-device capacity full."))


