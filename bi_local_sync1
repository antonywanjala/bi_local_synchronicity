def load_local_variables(filepath):
    local_vars = {}
    if os.path.exists(filepath):
        with open(filepath, 'r', encoding='utf-8') as f:
            for line in f:
                line = line.strip()
                if ":" in line and not line.startswith("#"):
                    key, val = line.split(":", 1)
                    local_vars[key.strip()] = val.strip()
    return local_vars


def parse_syntax(content, my_id, local_vars, log_queue, api_lock, intra_sem, choice, lock_wait):
    blocks = content.split('[Subprocess')
    device_task_count = 0  # Counter to calculate stagger delay

    for block in blocks:
        if not block.strip(): continue

        try:
            slot_id = block.split(':')[0].strip()
            if not slot_id: slot_id = "Unknown"
        except Exception:
            slot_id = "Unknown"

        full_block = '[Subprocess' + block

        if "NOT FUNCTIONAL" in full_block:
            if slot_id in active_subprocesses:
                proc = active_subprocesses[slot_id]
                if proc.is_alive():
                    log_queue.put((slot_id, "Shutting down: Status changed to NOT FUNCTIONAL"))
                    proc.terminate()
                    proc.join()
                del active_subprocesses[slot_id]
            continue

        if "FUNCTIONAL" in full_block:
            context_vars = local_vars.copy()
            lines = full_block.split('\n')
            run_triggered = False

            for line in lines:
                while "[" in line and "]" in line:
                    start = line.find("[")
                    end = line.find("]") + 1
                    line = line[:start] + line[end:]
                line = line.lstrip('\ufeff ').strip()

                if not line or line.startswith(("#", "[Sub")): continue

                if ":" in line and not line.startswith("run"):
                    key, val = line.split(":", 1)
                    clean_key = key.split(']')[-1].strip() if ']' in key else key.strip()
                    context_vars[clean_key] = val.strip()
                elif line.startswith("run:"):
                    run_content = line.replace("run:", "").strip()
                    if " " in run_content:
                        parts = run_content.split()
                        if len(parts) >= 2:
                            context_vars['script_path'] = parts
                            context_vars['run'] = parts
                    else:
                        context_vars['run'] = run_content
                    run_triggered = True

            if str(context_vars.get('target_device', '1')).strip() == my_id:
                if run_triggered:
                    if slot_id not in active_subprocesses or not active_subprocesses[slot_id].is_alive():
                        # Calculate staggered delay (e.g., 5 seconds delay per sequential task)
                        start_delay = device_task_count * 5
                        device_task_count += 1

                        p = multiprocessing.Process(
                            target=concurrency_wrapper,
                            args=(start_delay, intra_sem, slot_id, log_queue, api_lock, my_id, choice, lock_wait),
                            kwargs=context_vars
                        )
                        p.start()
                        active_subprocesses[slot_id] = p


def logger_worker(log_queue):
    while True:
        try:
            record = log_queue.get(timeout=1)
            if record == "STOP": break
            if isinstance(record, (tuple, list)) and len(record) == 2:
                slot, text = record
                print(f"[{datetime.now().strftime('%H:%M:%S')}] Subprocess {slot}: {text}", flush=True)
        except queue.Empty:
            continue


def instruction_builder(my_device, choice, intra_sem):
    draft = ""
    if os.path.exists(DRAFT_FILE):
        with open(DRAFT_FILE, "r") as f: draft = f.read()

    while True:
        print(f"\n--- Instruction Builder (Device: {my_device}) ---")
        print("1. Add Standard Sync Step (Upload/Download)")
        print("2. Add Dynamic Remote Subroutine Step (Script path + function)")
        print("3. View/Clear Draft")
        print("4. Instantiate Locally / Publish Extralocally")
        print("5. Go Back to Main Menu")
        sub_choice = input("> ").strip()

        if sub_choice == '1':
            s_id = input("Subprocess ID: ").strip()
            act = input("Action (upload/download): ").strip()
            dev = input("Target Device: ").strip()
            path = input("Local Path: ").strip()
            gid = input("GDrive ID: ").strip()
            draft += f"[Subprocess {s_id}: FUNCTIONAL]\naction: {act}\ntarget_device: {dev}\ntarget_path: {path}\ngdrive_target_id: {gid}\nrun: trigger_sync\n\n"

        elif sub_choice == '2':
            s_id = input("Subprocess ID: ").strip()
            dev = input("Target Device ID to run logic on: ").strip()
            py_path = input("Absolute Local Path to .py script: ").strip()
            func = input("Function Name inside script: ").strip()
            args = input("Comma-separated kwargs (e.g. speed: 10): ").strip()
            step = f"[Subprocess {s_id}: FUNCTIONAL]\ntarget_device: {dev}\n"
            for arg in args.split(','):
                if ':' in arg: step += f"{arg.strip()}\n"
            step += f"run: {py_path} {func}\n\n"
            draft += step
            print("✅ Dynamic remote step added.")

        elif sub_choice == '3':
            print(f"\n--- Current Draft ---\n{draft if draft else '[Empty]'}")
            if draft and input("Clear draft? (y/n): ").lower() == 'y':
                draft = ""
                if os.path.exists(DRAFT_FILE): os.remove(DRAFT_FILE)
                print("Draft has been cleared.")

        elif sub_choice == '4':
            if not draft: continue
            epoch = int(time.time())
            fname = f"generated_instructions_{epoch}.txt"

            if input("Publish to ExtraLocal Mediating Folder? (y/n): ").lower() == 'y':
                with open(fname, "w") as f: f.write(draft)
                _upload_item(get_drive_service(), fname, MONITOR_FOLDER_ID, multiprocessing.Queue(), "SYS", "BUILDER")
                print(f"✅ Published ExtraLocally as {fname}")

            if input("Run resultant instructions for local device role now? (y/n): ").lower() == 'y':
                print("Instantiating Local Roles... (Waiting for completion)")
                api_lock = multiprocessing.Lock()
                log_q = multiprocessing.Queue()
                lp = multiprocessing.Process(target=logger_worker, args=(log_q,))
                lp.start()

                local_vars = load_local_variables(LOCAL_VAR_FILE)
                parse_syntax(draft, my_device, local_vars, log_q, api_lock, intra_sem, choice, lock_wait=6)

                for slot, proc in list(active_subprocesses.items()):
                    proc.join()

                log_q.put("STOP")
                lp.join()
                print("Local instantiation complete.")
            break

        elif sub_choice == '5':
            break


def monitor_mode(my_id, intra_sem, p_int=6, lock_wait=6):
    api_lock = multiprocessing.Lock()
    log_queue = multiprocessing.Queue()
    lp = multiprocessing.Process(target=logger_worker, args=(log_queue,))
    lp.start()

    service = get_drive_service()
    known_files = {}

    print(f"Monitoring ExtraLocal Drive as Device {my_id}...")
    try:
        while True:
            try:
                local_vars = load_local_variables(LOCAL_VAR_FILE)
                # Ignore folders to avoid download crashes
                query = f"'{MONITOR_FOLDER_ID}' in parents and trashed=false and mimeType != 'application/vnd.google-apps.folder'"
                results = service.files().list(q=query, fields="files(id, name, modifiedTime, mimeType)").execute()

                for item in results.get('files', []):
                    f_id_item = item['id']
                    m_time = item['modifiedTime']

                    if "LOCK_" in item['name']: continue

                    if f_id_item not in known_files or known_files[f_id_item] != m_time:
                        known_files[f_id_item] = m_time

                        # Handle GDocs and standard text files appropriately
                        if item['mimeType'] == 'application/vnd.google-apps.document':
                            request = service.files().export_media(fileId=f_id_item, mimeType='text/plain')
                        else:
                            request = service.files().get_media(fileId=f_id_item)

                        content = request.execute().decode('utf-8', errors='ignore')
                        parse_syntax(content, my_id, local_vars, log_queue, api_lock, intra_sem, '2', lock_wait)
            except Exception as e:
                print(f"Polling Error: {e}")
            time.sleep(p_int)
    except KeyboardInterrupt:
        log_queue.put("STOP")
        lp.join()
        for p in active_subprocesses.values():
            if p.is_alive(): p.terminate()


